---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { faqItems } from "../../data/faq";
import { links } from "../../data/links";
---

<section id="faq" class="py-20 sm:py-24">
  <Container className="grid gap-12 lg:grid-cols-[0.7fr_1.3fr]">
    <div>
      <SectionHeader
        eyebrow="FAQ"
        title="Tanya dulu juga boleh."
        description="Kami sengaja jujur karena Sakala masih tahap awal."
      />
      <p
        class="mt-8 rounded-xl border border-border bg-surface px-4 py-3 text-sm text-muted"
      >
        Ada pertanyaan lain? Mulai dari <a
          class="font-semibold text-primary underline decoration-primary-soft underline-offset-4 hover:text-primary-dark"
          href={links.githubIssues}
          target="_blank"
          rel="noreferrer">issue di GitHub</a
        >.
      </p>
    </div>
    <div class="space-y-3">
      {
        faqItems.map((item, index) => (
          <details
            class="paper-card group rounded-xl border border-border bg-surface p-5"
            open={index === 0}
          >
            <summary class="flex min-h-11 cursor-pointer list-none items-start justify-between gap-4 font-semibold text-ink">
              {item.question}
              <span class="rounded-full bg-background-soft px-2 text-lg leading-6 text-primary group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-4 max-w-2xl border-t border-dashed border-border pt-4 leading-7 text-muted">
              {item.answer}
            </p>
          </details>
        ))
      }
    </div>
  </Container>
</section>
