---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { useCases } from "../../data/use-cases";

const sizeClass = {
  large: "md:col-span-7 md:row-span-2 bg-primary text-white",
  small: "md:col-span-5 bg-surface",
  medium: "md:col-span-5 bg-accent-soft",
  wide: "md:col-span-7 bg-surface-elevated",
};
---

<section id="use-cases" class="bg-surface py-20 sm:py-28">
  <Container>
    <SectionHeader
      eyebrow="Untuk kelas dan project kecil"
      title="Yang kamu buat layak dilihat sebagai aplikasi."
      description="Bukan untuk jargon enterprise. Untuk tugas, portfolio, workshop, dan demo yang ingin segera dibuka orang lain."
    />
    <div class="mt-12 grid gap-4 md:grid-cols-12 md:auto-rows-[10.5rem]">
      {
        useCases.map((item) => (
          <article
            class:list={[
              "paper-card group relative overflow-hidden rounded-2xl border border-border p-6",
              sizeClass[item.size as keyof typeof sizeClass],
            ]}
          >
            <p
              class:list={[
                "font-mono text-[11px] uppercase tracking-[0.18em]",
                item.size === "large" ? "text-primary-soft" : "text-primary",
              ]}
            >
              {item.label}
            </p>
            <h3
              class:list={[
                "mt-4 text-2xl font-semibold tracking-tight",
                item.size === "large" ? "text-white" : "text-ink",
              ]}
            >
              {item.title}
            </h3>
            <p
              class:list={[
                "mt-3 max-w-md text-sm leading-7",
                item.size === "large" ? "text-primary-soft" : "text-muted",
              ]}
            >
              {item.description}
            </p>
            {item.size === "large" && (
              <p class="absolute bottom-6 right-6 hidden -rotate-3 rounded-lg bg-white px-3 py-2 text-xs font-medium text-primary-dark sm:block">
                link &gt; screenshot
              </p>
            )}
          </article>
        ))
      }
    </div>
  </Container>
</section>
