---
import Card from "../ui/Card.astro";
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { useCases } from "../../data/use-cases";
---

<section id="use-cases" class="bg-surface py-20 sm:py-24">
  <Container>
    <SectionHeader
      eyebrow="Untuk siapa"
      title="Dibuat untuk project yang perlu segera dibagikan."
      description="Sakala berangkat dari pembelajaran dan tim yang membutuhkan jalur deployment yang tenang serta masuk akal."
    />
    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {
        useCases.map((item) => (
          <Card class="bg-surface-elevated">
            <h3 class="text-xl font-semibold text-ink">{item.title}</h3>
            <p class="mt-3 leading-7 text-muted">{item.description}</p>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
