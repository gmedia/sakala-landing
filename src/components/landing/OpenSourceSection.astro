---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const principles = [
  [
    "Dibangun terbuka",
    "Keputusan dan perkembangan bisa diikuti lewat repository.",
  ],
  [
    "Bisa dipelajari",
    "Proses deploy dibuat transparan supaya bisa dipahami pelan-pelan.",
  ],
  [
    "Bisa dikontribusi",
    "Dokumentasi, issue, UI, dan arsitektur tumbuh dari masukan nyata.",
  ],
];

const repositories = [
  ["sakala-dashboard", "panel kontrol"],
  ["sakala-agent", "eksekutor runtime"],
  ["sakala-infra", "playground lokal"],
  ["sakala-landing", "website & dokumentasi"],
];
---

<section id="open-source" class="relative py-20 sm:py-24">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <SectionHeader
          eyebrow="Open source"
          title="Dibangun terbuka. Bisa dipelajari, bisa dioprek."
          description="Sakala masih dibangun. Versi yang stabil perlu tumbuh dari kebutuhan kelas, komunitas, dan pengguna awal."
        />
        <div class="mt-8">
          <Button href="https://github.com/gmedia" external>Lihat GitHub</Button
          >
        </div>
      </div>

      <div class="space-y-4">
        <div class="grid gap-3 sm:grid-cols-3">
          {
            principles.map(([title, text]) => (
              <article class="paper-card rounded-xl border border-border bg-surface p-4">
                <h3 class="font-semibold text-ink">{title}</h3>
                <p class="mt-3 text-sm leading-6 text-muted">{text}</p>
              </article>
            ))
          }
        </div>
        <div
          class="rounded-xl border border-border bg-surface-elevated p-5 font-mono text-xs"
        >
          <p class="mb-4 text-primary">$ lihat ekosistem/</p>
          <div class="grid gap-3 sm:grid-cols-2">
            {
              repositories.map(([repo, role]) => (
                <p class="flex items-center justify-between gap-3 rounded-lg bg-background px-3 py-2">
                  <span class="text-ink">{repo}</span>
                  <span class="text-muted-2">{role}</span>
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
