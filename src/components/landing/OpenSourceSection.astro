---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";

const principles = [
  ["Dibangun terbuka", "Keputusan dan progress bisa diikuti lewat repository."],
  [
    "Bisa dipelajari",
    "Runtime tidak disembunyikan di balik klaim yang berlebihan.",
  ],
  [
    "Bisa dikontribusi",
    "Docs, issue, UI, dan arsitektur tumbuh dari feedback nyata.",
  ],
];

const repositories = [
  "sakala-dashboard",
  "sakala-agent",
  "sakala-infra",
  "sakala-landing",
];
---

<section id="open-source" class="relative py-20 sm:py-28">
  <Container>
    <div
      class="relative overflow-hidden rounded-[2rem] border border-border bg-terminal px-6 py-9 text-terminal-text sm:px-10 sm:py-12"
    >
      <div
        class="absolute right-8 top-8 font-mono text-[11px] uppercase tracking-[0.2em] text-primary-soft/60"
      >
        public / apache-2.0
      </div>
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.18em] text-primary-soft"
          >
            Open source
          </p>
          <h2
            class="mt-5 text-3xl font-semibold tracking-tight text-white sm:text-5xl"
          >
            Gratis untuk belajar. Transparan untuk dioprek.
          </h2>
          <p class="mt-5 max-w-md leading-8 text-terminal-text/75">
            Sakala masih dibangun. Justru itu: versi yang stabil bisa tumbuh
            dari kebutuhan kelas, komunitas, dan builder sungguhan.
          </p>
          <div class="mt-8">
            <Button href="https://github.com/gmedia" external
              >Lihat GitHub</Button
            >
          </div>
        </div>
        <div>
          <div class="grid gap-3 sm:grid-cols-3">
            {
              principles.map(([title, text]) => (
                <article class="rounded-xl border border-white/10 bg-terminal-soft p-4">
                  <h3 class="font-semibold text-white">{title}</h3>
                  <p class="mt-3 text-sm leading-6 text-terminal-text/65">
                    {text}
                  </p>
                </article>
              ))
            }
          </div>
          <div
            class="mt-5 rounded-xl border border-white/10 bg-terminal-soft p-5 font-mono text-xs"
          >
            <p class="mb-4 text-primary-soft">$ ls ecosystem/</p>
            <div class="grid gap-3 text-terminal-text/80 sm:grid-cols-2">
              {
                repositories.map((repo) => (
                  <p>
                    <span class="text-success">+</span> {repo}
                  </p>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
