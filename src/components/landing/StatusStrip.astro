---
import Container from "../ui/Container.astro";

const statuses = [
  { name: "Dashboard foundation", state: "ready", ready: true },
  { name: "Agent foundation", state: "ready", ready: true },
  { name: "Infra playground", state: "ready", ready: true },
  { name: "First deployment flow", state: "in progress", ready: false },
];
---

<section
  aria-label="Status pengembangan Sakala"
  class="border-y border-border bg-surface/80"
>
  <Container className="flex flex-col gap-4 py-5 lg:flex-row lg:items-center">
    <p
      class="shrink-0 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-muted"
    >
      build log / now
    </p>
    <div class="grid flex-1 gap-2 sm:grid-cols-2 lg:grid-cols-4">
      {
        statuses.map((status) => (
          <div class="flex items-center justify-between gap-3 rounded-lg border border-border bg-background px-3 py-2 font-mono text-[11px]">
            <span class="text-muted">{status.name}</span>
            <span
              class:list={[
                "flex items-center gap-1.5",
                status.ready ? "text-success" : "text-warm",
              ]}
            >
              <span
                class:list={[
                  "size-1.5 rounded-full",
                  status.ready ? "bg-success" : "bg-warm",
                ]}
              />
              {status.state}
            </span>
          </div>
        ))
      }
    </div>
  </Container>
</section>
