---
import Container from "../ui/Container.astro";
import { developmentStatuses } from "../../data/roadmap";

const toneClass = {
  ready: "text-success",
  progress: "text-warm",
  later: "text-muted",
};

const dotClass = {
  ready: "bg-success",
  progress: "bg-warm",
  later: "bg-muted-2",
};
---

<section
  aria-label="Status pengembangan Sakala"
  class="border-y border-border bg-surface/80"
>
  <Container className="flex flex-col gap-4 py-4 lg:flex-row lg:items-center">
    <p
      class="shrink-0 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-muted"
    >
      status singkat
    </p>
    <div class="grid flex-1 gap-2 sm:grid-cols-2 lg:grid-cols-4">
      {
        developmentStatuses.map((status) => (
          <div class="flex items-center justify-between gap-3 rounded-lg border border-border bg-background px-3 py-2 text-xs">
            <span class="text-muted">{status.name}</span>
            <span
              class:list={["flex items-center gap-1.5", toneClass[status.tone]]}
            >
              <span
                class:list={["size-1.5 rounded-full", dotClass[status.tone]]}
              />
              {status.state}
            </span>
          </div>
        ))
      }
    </div>
  </Container>
</section>
