---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import DeploymentReceipt from "./DeploymentReceipt.astro";
import FlowPath from "./FlowPath.astro";
---

<section class="relative isolate overflow-hidden pb-18 pt-9 sm:pb-24 sm:pt-14">
  <div
    class="editorial-grid absolute inset-x-0 top-0 -z-10 h-[34rem] opacity-55 [mask-image:linear-gradient(to_bottom,black,transparent)]"
  >
  </div>
  <Container>
    <div class="relative">
      <div class="mb-8 flex flex-wrap items-center gap-3">
        <Badge>Open-source deployment platform in active development</Badge>
        <span
          class="float-note hidden -rotate-2 rounded-full border border-warm/30 bg-accent-soft px-4 py-2 text-xs font-medium text-warm sm:inline-flex"
        >
          bukan cuma screenshot
        </span>
      </div>

      <div
        class="grid gap-12 lg:grid-cols-[minmax(0,1.06fr)_24rem] lg:items-start"
      >
        <div class="relative">
          <h1
            class="max-w-[13ch] text-[clamp(3.5rem,8.7vw,7.15rem)] font-semibold leading-[0.93] tracking-[-0.065em] text-ink"
          >
            Dari repo<br />
            ke URL <span class="hand-underline text-primary-dark">publik.</span
            ><br />
            Tanpa ritual<br class="hidden sm:block" /> server.
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-8 text-muted sm:text-xl">
            Sakala membantu project tugas, portfolio, dan demo kecil keluar dari
            localhost tanpa harus mulai dari VPS, SSL, reverse proxy, atau
            Docker networking.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <Button href="https://github.com/gmedia" external
              >Lihat GitHub</Button
            >
            <Button href="/docs" variant="secondary">Baca Dokumentasi</Button>
            <Button href="https://app.sakala.dev" variant="ghost"
              >Masuk ke Dashboard</Button
            >
          </div>
        </div>

        <div class="relative pt-3 lg:pt-16">
          <span
            style="--note-rotate: 3deg"
            class="float-note absolute -right-2 -top-6 z-10 rotate-3 rounded-lg border border-primary-soft bg-primary-soft-2 px-3 py-2 text-xs font-semibold text-primary-dark sm:right-5 lg:-top-1"
          >
            git push, terus live
          </span>
          <DeploymentReceipt />
          <div
            class="-ml-5 mt-5 rounded-2xl border border-border bg-surface/90 p-3 sm:-ml-14"
          >
            <FlowPath />
          </div>
          <span
            style="--note-rotate: -3deg"
            class="float-note absolute -bottom-9 left-5 -rotate-3 rounded-lg border border-border-strong bg-surface px-3 py-2 text-[11px] font-medium text-muted"
          >
            localhost is not a submission
          </span>
        </div>
      </div>

      <p
        class="mt-20 max-w-3xl border-l-2 border-warm pl-4 text-sm leading-7 text-muted sm:mt-14"
      >
        <span class="font-semibold text-ink">Masih dibangun.</span>
        Sakala sedang menyusun pengalaman deployment yang sederhana, transparan, dan
        ramah untuk pembelajaran. Justru itu: kamu bisa ikut membentuk arahnya.
      </p>
    </div>
  </Container>
</section>
