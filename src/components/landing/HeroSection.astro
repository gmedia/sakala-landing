---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import DeploymentReceipt from "./DeploymentReceipt.astro";
import FlowPath from "./FlowPath.astro";
import { links } from "../../data/links";
---

<section class="relative isolate overflow-hidden pb-18 pt-9 sm:pb-24 sm:pt-14">
  <div
    class="editorial-grid absolute inset-x-0 top-0 -z-10 h-[34rem] opacity-45 [mask-image:linear-gradient(to_bottom,black,transparent)]"
  >
  </div>
  <Container>
    <div class="relative">
      <div class="mb-8">
        <Badge
          >Sakala · platform deployment open-source dalam pengembangan aktif</Badge
        >
      </div>

      <div
        class="grid gap-12 lg:grid-cols-[minmax(0,1.08fr)_23rem] lg:items-start"
      >
        <div class="relative">
          <h1
            class="max-w-[13ch] text-[clamp(3.5rem,8.4vw,6.9rem)] font-semibold leading-[0.94] tracking-[-0.06em] text-ink"
          >
            Dari repo<br />
            ke URL <span class="hand-underline text-primary-dark">publik.</span
            ><br />
            Tanpa ritual<br class="hidden sm:block" /> server.
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-8 text-muted sm:text-xl">
            Sakala membantu tugas, portfolio, dan demo kecil bergerak keluar
            dari localhost. Mulai dari link yang bisa dibuka, sambil memahami
            infrastrukturnya pelan-pelan.
          </p>
          <div class="mt-9 flex flex-wrap items-center gap-3">
            <Button href="/docs" prefetch="hover">Baca Dokumentasi</Button>
            <Button href={links.githubRepository} variant="secondary" external
              >Lihat Repository</Button
            >
            <a
              href={links.dashboard}
              class="inline-flex min-h-11 items-center px-2 text-sm font-semibold text-primary hover:text-primary-dark"
            >
              Masuk ke Dashboard
            </a>
          </div>
        </div>

        <div class="relative pt-3 lg:pt-12">
          <span
            class="absolute -right-2 -top-6 z-10 rotate-2 rounded-lg border border-primary-soft bg-primary-soft-2 px-3 py-2 text-xs font-semibold text-primary-dark sm:right-5 lg:top-0"
          >
            preview alur
          </span>
          <DeploymentReceipt />
          <div
            class="-ml-4 mt-5 rounded-2xl border border-border bg-surface/90 p-3 sm:-ml-10"
          >
            <FlowPath />
          </div>
        </div>
      </div>

      <p
        class="mt-16 max-w-3xl border-l-2 border-warm pl-4 text-sm leading-7 text-muted"
      >
        <span class="font-semibold text-ink">Masih dibangun.</span>
        Sakala sedang menyusun pengalaman deployment yang sederhana, transparan, dan
        ramah untuk pembelajaran.
      </p>
    </div>
  </Container>
</section>
