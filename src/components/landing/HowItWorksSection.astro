---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const steps = [
  {
    title: "Hubungkan repo",
    text: "Pilih project Git yang mau kamu keluarkan dari laptop.",
    chip: "repo terhubung",
  },
  {
    title: "Sakala menyiapkan deployment",
    text: "Proses deploy dibuat terbaca, bukan sekadar tombol ajaib.",
    chip: "build masuk",
  },
  {
    title: "URL publik siap dibagikan",
    text: "Kirim link ke dosen, teman, komunitas, atau calon pengguna.",
    chip: "link siap",
  },
];
---

<section id="cara-kerja" class="relative overflow-hidden py-20 sm:py-24">
  <Container>
    <SectionHeader
      eyebrow="Cara kerja"
      title="Mulai dari deploy. Pahami infrastrukturnya pelan-pelan."
      description="Tiga langkah yang terasa familiar untuk developer, dengan proses yang tetap transparan."
    />
    <div class="relative mt-14 grid gap-5 lg:grid-cols-3">
      <div
        class="absolute left-10 right-10 top-9 hidden border-t border-dashed border-primary-soft lg:block"
      >
      </div>
      {
        steps.map((step, index) => (
          <article class="paper-card relative rounded-2xl border border-border bg-surface p-6 pt-7">
            <div class="relative flex items-center justify-between">
              <span class="flex size-10 items-center justify-center rounded-full border-4 border-primary-soft-2 bg-primary text-sm font-semibold text-white">
                {index + 1}
              </span>
              <span class="rounded-full bg-primary-soft-2 px-3 py-1 font-mono text-[11px] text-primary-dark">
                {step.chip}
              </span>
            </div>
            <h3 class="mt-8 text-xl font-semibold tracking-tight text-ink">
              {step.title}
            </h3>
            <p class="mt-3 leading-7 text-muted">{step.text}</p>
          </article>
        ))
      }
    </div>
    <div
      class="mt-14 flex flex-col gap-5 border-l-2 border-primary pl-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p
        class="max-w-2xl text-xl font-semibold tracking-tight text-ink sm:text-2xl"
      >
        Dosen tinggal buka link. Mahasiswa belajar deployment beneran.
      </p>
      <span
        class="shrink-0 rounded-full border border-border bg-surface px-5 py-3 font-mono text-xs text-primary"
      >
        repo -&gt; deploy -&gt; link
      </span>
    </div>
  </Container>
</section>
