---
import SakalaLogo from "../brand/SakalaLogo.astro";
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import MobileNav from "./MobileNav.astro";
import { links } from "../../data/links";
import { mainNavigation } from "../../data/navigation";

const currentPath =
  Astro.url.pathname.length > 1
    ? Astro.url.pathname.replace(/\/$/, "")
    : Astro.url.pathname;
---

<header
  class="sticky top-0 z-30 border-b border-border/70 bg-background/85 backdrop-blur"
>
  <Container className="flex h-18 items-center justify-between">
    <SakalaLogo />
    <nav class="hidden items-center gap-7 md:flex" aria-label="Navigasi utama">
      {
        mainNavigation.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer" : undefined}
            data-astro-prefetch={item.external ? undefined : "hover"}
            aria-current={currentPath === item.href ? "page" : undefined}
            class:list={[
              "inline-flex min-h-11 items-center border-b-2 text-sm font-medium hover:text-primary",
              currentPath === item.href
                ? "border-primary text-primary-dark"
                : "border-transparent text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="hidden items-center gap-3 md:flex">
      <Button href={links.dashboard} variant="secondary">Masuk</Button>
    </div>
    <MobileNav />
  </Container>
</header>
