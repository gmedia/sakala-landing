---
import SakalaLogo from "../brand/SakalaLogo.astro";
import Container from "../ui/Container.astro";
import { links } from "../../data/links";
---

<footer class="border-t border-border bg-surface">
  <Container className="grid gap-10 py-12 sm:grid-cols-[1fr_auto_auto]">
    <div>
      <SakalaLogo />
      <p class="mt-4 max-w-sm text-sm leading-7 text-muted">
        Sakala membantu project kecil keluar dari laptop dan menjadi link yang
        bisa dibuka, dipelajari, dan dibagikan.
      </p>
    </div>
    <div class="space-y-3 text-sm">
      <p class="font-semibold text-ink">Navigasi</p>
      <a class="block text-muted hover:text-primary" href="/docs">Dokumentasi</a
      >
      <a class="block text-muted hover:text-primary" href="/tentang">Tentang</a>
      <a class="block text-muted hover:text-primary" href="/changelog"
        >Changelog</a
      >
      <a
        class="block text-muted hover:text-primary"
        href={links.githubRepository}
        target="_blank"
        rel="noreferrer">Repository</a
      >
    </div>
    <div class="space-y-3 text-sm">
      <p class="font-semibold text-ink">Open source</p>
      <a
        class="block text-muted hover:text-primary"
        href={links.githubOrganization}
        target="_blank"
        rel="noreferrer">GitHub GMEDIA</a
      >
      <a class="block text-muted hover:text-primary" href="/docs/concepts"
        >Konsep</a
      >
      <a class="block text-muted hover:text-primary" href="/docs/faq">FAQ</a>
      <a class="block text-muted hover:text-primary" href="/rss.xml"
        >RSS Changelog</a
      >
    </div>
  </Container>
  <div class="border-t border-border py-5 text-center text-sm text-muted">
    &copy; {new Date().getFullYear()} PT Media Sarana Data (GMEDIA). Licensed under
    Apache-2.0.
  </div>
</footer>
