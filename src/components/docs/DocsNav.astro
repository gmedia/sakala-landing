---
import { docsNavigation } from "../../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const currentIndex = docsNavigation.findIndex(
  (item) => item.href === currentPath,
);
const previous =
  currentIndex > 0 ? docsNavigation[currentIndex - 1] : undefined;
const next = currentIndex >= 0 ? docsNavigation[currentIndex + 1] : undefined;
---

<nav
  class="mt-14 flex justify-between gap-4 border-t border-border pt-6 text-sm"
>
  <div>
    {
      previous && (
        <a href={previous.href} class="text-primary hover:text-primary-dark">
          &larr; {previous.label}
        </a>
      )
    }
  </div>
  <div>
    {
      next && (
        <a href={next.href} class="text-primary hover:text-primary-dark">
          {next.label} &rarr;
        </a>
      )
    }
  </div>
</nav>
