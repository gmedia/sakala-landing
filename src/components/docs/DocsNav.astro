---
import { docsNavigation } from "../../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const currentIndex = docsNavigation.findIndex(
  (item) => item.href === currentPath,
);
const previous =
  currentIndex > 0 ? docsNavigation[currentIndex - 1] : undefined;
const next = currentIndex >= 0 ? docsNavigation[currentIndex + 1] : undefined;
---

<nav
  class="mt-14 grid gap-3 border-t border-border pt-6 text-sm sm:grid-cols-2"
  aria-label="Halaman dokumentasi"
>
  <div class="min-w-0">
    {
      previous && (
        <a
          href={previous.href}
          data-astro-prefetch="hover"
          class="flex min-h-16 flex-col justify-center rounded-xl border border-border bg-surface px-4 py-3 text-primary hover:border-primary hover:text-primary-dark"
        >
          <span class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">
            Sebelumnya
          </span>
          <span class="mt-1 font-semibold">&larr; {previous.label}</span>
        </a>
      )
    }
  </div>
  <div class="min-w-0">
    {
      next && (
        <a
          href={next.href}
          data-astro-prefetch="hover"
          class="flex min-h-16 flex-col items-end justify-center rounded-xl border border-border bg-surface px-4 py-3 text-right text-primary hover:border-primary hover:text-primary-dark"
        >
          <span class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">
            Berikutnya
          </span>
          <span class="mt-1 font-semibold">{next.label} &rarr;</span>
        </a>
      )
    }
  </div>
</nav>
