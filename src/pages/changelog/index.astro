---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import Container from "../../components/ui/Container.astro";
import LandingLayout from "../../layouts/LandingLayout.astro";

const entries = (await getCollection("changelog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
const date = new Intl.DateTimeFormat("id-ID", { dateStyle: "long" });
const breadcrumbs = [{ label: "Beranda", href: "/" }, { label: "Changelog" }];
---

<LandingLayout
  title="Changelog — Sakala"
  description="Ikuti pembaruan publik Sakala, termasuk landing page, dokumentasi, console, API, agent, dan fondasi deployment open-source."
  pageType="CollectionPage"
  {breadcrumbs}
>
  <Container className="py-16 sm:py-20">
    <Breadcrumbs items={breadcrumbs} />
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
      Changelog
    </p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-ink">
      Perjalanan pengembangan Sakala.
    </h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">
      Pembaruan penting website, dokumentasi, dan fondasi produk yang dapat
      diikuti secara terbuka.
    </p>
    <div class="mt-14 space-y-6">
      {
        entries.map((entry) => (
          <article
            id={`v-${entry.data.version}`}
            class="grid scroll-mt-28 gap-5 rounded-2xl border border-border bg-surface p-7 md:grid-cols-[12rem_1fr]"
          >
            <div>
              <p class="font-mono text-sm font-semibold text-primary">
                v{entry.data.version}
              </p>
              <time
                class="mt-2 block text-sm text-muted"
                datetime={entry.data.publishedAt.toISOString()}
              >
                {date.format(entry.data.publishedAt)}
              </time>
            </div>
            <div>
              <h2 class="text-xl font-semibold text-ink">{entry.data.title}</h2>
              <p class="mt-3 leading-7 text-muted">{entry.data.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</LandingLayout>
