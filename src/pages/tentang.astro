---
import { Image } from "astro:assets";
import EarlyContributorsSection from "../components/about/EarlyContributorsSection.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import Card from "../components/ui/Card.astro";
import Container from "../components/ui/Container.astro";
import { links } from "../data/links";
import LandingLayout from "../layouts/LandingLayout.astro";

const breadcrumbs = [
  { label: "Beranda", href: "/" },
  { label: "Tentang Sakala" },
];
const ecosystem = [
  {
    name: "sakala-dashboard",
    role: "Control plane untuk project, command, status, dan pengalaman pengguna.",
    href: links.repositories.dashboard,
  },
  {
    name: "sakala-agent",
    role: "Runtime executor yang menangani pekerjaan deployment pada node.",
    href: links.repositories.agent,
  },
  {
    name: "sakala-infra",
    role: "Playground runtime lokal serta referensi networking dan routing.",
    href: links.repositories.infra,
  },
  {
    name: "sakala-landing",
    role: "Website publik, dokumentasi, dan pintu masuk informasi Sakala.",
    href: links.repositories.landing,
  },
];
---

<LandingLayout
  title="Tentang Sakala — Project Deployment Open-Source"
  description="Kenali tujuan Sakala, prinsip open-source, dukungan founding sponsor, dan arah komunitas project deployment Sakala."
  pageType="AboutPage"
  {breadcrumbs}
>
  <Container className="py-16 sm:py-20">
    <Breadcrumbs items={breadcrumbs} />
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
        Tentang Sakala
      </p>
      <h1
        class="mt-4 text-4xl font-semibold tracking-tight text-ink sm:text-5xl"
      >
        Deployment yang lebih mudah dipelajari.
      </h1>
      <p class="mt-6 text-lg leading-8 text-muted">
        Sakala adalah project deployment open-source yang membantu developer
        membawa project dari repository Git menuju URL publik melalui alur yang
        lebih sederhana dan mudah dipahami.
      </p>
      <p class="mt-4 text-lg leading-8 text-muted">
        Fokus awalnya sederhana: membantu project keluar dari localhost, tanpa
        harus langsung berhadapan dengan VPS, SSL, reverse proxy, Docker
        networking, dan konfigurasi server manual.
      </p>
    </div>

    <div class="mt-14 grid gap-5 lg:grid-cols-2">
      <Card>
        <p
          class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
        >
          Tujuan
        </p>
        <h2 class="mt-3 text-2xl font-semibold text-ink">
          Ramah untuk belajar dan berbagi
        </h2>
        <p class="mt-4 leading-7 text-muted">
          Fokus awal Sakala adalah tugas, portfolio, demo, kelas, komunitas, dan
          tim kecil. Sakala tidak diarahkan menjadi pengganti cloud enterprise.
        </p>
      </Card>
      <Card>
        <p
          class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
        >
          Status
        </p>
        <h2 class="mt-3 text-2xl font-semibold text-ink">
          Masih dalam pengembangan aktif
        </h2>
        <p class="mt-4 leading-7 text-muted">
          Foundation produk dan runtime masih disusun. Dokumentasi dan changelog
          menjelaskan perkembangan nyata tanpa mengklaim layanan siap
          production.
        </p>
      </Card>
    </div>

    <section class="mt-16" aria-labelledby="open-source-title">
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div>
          <p
            class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
          >
            Open-source first
          </p>
          <h2
            id="open-source-title"
            class="mt-3 text-3xl font-semibold text-ink"
          >
            Terbuka agar bisa dipelajari, diaudit, dan dikembangkan bersama.
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-8 text-muted">
          <p>
            Kode, dokumentasi, issue, roadmap, dan proses pengembangan Sakala
            dibuka supaya keputusan teknisnya dapat dibaca dan dikritisi secara
            publik.
          </p>
          <p>
            Sakala tidak dimulai sebagai cloud besar atau produk enterprise.
            Sakala dimulai sebagai ruang belajar dan eksperimen deployment yang
            praktis, lalu bertumbuh berdasarkan kebutuhan nyata pengguna dan
            contributor.
          </p>
        </div>
      </div>
    </section>

    <section class="mt-16" aria-labelledby="sponsor-title">
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div>
          <p
            class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
          >
            Dukungan awal
          </p>
          <h2 id="sponsor-title" class="mt-3 text-3xl font-semibold text-ink">
            Didukung oleh GMEDIA sebagai sponsor pendiri.
          </h2>
          <p class="mt-5 leading-7 text-muted">
            GMEDIA membantu Sakala mencapai MVP dan pilot awal melalui dukungan
            infrastruktur, domain, ruang eksperimen, dan dukungan teknis.
          </p>
        </div>
        <div
          class="rounded-3xl border border-border-strong bg-surface p-6 shadow-[0_18px_60px_rgba(15,118,110,0.08)]"
        >
          <p
            class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
          >
            Founding Sponsor & Infrastructure Supporter
          </p>
          <div
            class="mt-5 rounded-2xl border border-border bg-background px-5 py-6 flex items-center justify-center"
          >
            <Image
              src="/sponsors/gmedia.png"
              width="720"
              height="259"
              loading="lazy"
              alt="GMEDIA - PT Media Sarana Data"
              class="h-auto w-full max-w-sm"
            />
          </div>
          <p class="mt-5 leading-7 text-muted">
            Dukungan GMEDIA tidak mengubah prinsip dasar Sakala sebagai project
            open-source. Roadmap, dokumentasi, issue, dan kontribusi tetap
            dikembangkan secara terbuka.
          </p>
        </div>
      </div>
    </section>

    <section class="mt-16" aria-labelledby="governance-title">
      <div class="max-w-3xl">
        <p
          class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
        >
          Governance
        </p>
        <h2 id="governance-title" class="mt-3 text-3xl font-semibold text-ink">
          Sponsor mendukung, maintainer menjaga arah project.
        </h2>
        <p class="mt-5 text-lg leading-8 text-muted">
          Pada tahap awal, Sakala masih dikembangkan di dalam ekosistem GitHub
          GMEDIA untuk mempercepat setup, validasi, dan kolaborasi internal.
          Saat MVP lebih stabil dan kontribusi publik mulai tumbuh, Sakala
          diarahkan untuk bergerak menuju model governance komunitas yang lebih
          terbuka.
        </p>
        <p class="mt-4 text-lg leading-8 text-muted">
          Sponsor tidak otomatis mengontrol keputusan teknis, prioritas roadmap,
          perubahan lisensi, atau hak contributor. Sakala tetap menggunakan
          Apache License 2.0.
        </p>
        <a
          href="/governance"
          class="mt-6 inline-flex min-h-11 items-center font-semibold text-primary-dark underline decoration-primary-soft decoration-2 underline-offset-4 hover:decoration-primary"
        >
          Baca governance project &rarr;
        </a>
      </div>
    </section>

    <EarlyContributorsSection />

    <section class="mt-16" aria-labelledby="ecosystem-title">
      <p
        class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-primary"
      >
        Ekosistem repository
      </p>
      <h2 id="ecosystem-title" class="mt-3 text-3xl font-semibold text-ink">
        Tanggung jawab yang dipisahkan dengan jelas
      </h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          ecosystem.map((repository) => (
            <a
              href={repository.href}
              target="_blank"
              rel="noreferrer"
              class="group rounded-2xl border border-border bg-surface p-6 hover:border-primary"
            >
              <h3 class="font-mono font-semibold text-primary-dark group-hover:underline">
                {repository.name}
              </h3>
              <p class="mt-3 leading-7 text-muted">{repository.role}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section
      class="mt-16 rounded-2xl border border-border-strong bg-primary-soft-2 p-7 sm:p-9"
      aria-labelledby="next-step-title"
    >
      <h2 id="next-step-title" class="text-2xl font-semibold text-ink">
        Pelajari arah teknis Sakala
      </h2>
      <p class="mt-3 max-w-2xl leading-7 text-muted">
        Dokumentasi menjelaskan peran dashboard, agent, infra, serta alur
        deployment yang sedang dibangun.
      </p>
      <a
        href="/docs"
        data-astro-prefetch="hover"
        class="mt-6 inline-flex min-h-11 items-center font-semibold text-primary-dark underline decoration-primary-soft decoration-2 underline-offset-4 hover:decoration-primary"
      >
        Baca dokumentasi Sakala &rarr;
      </a>
    </section>
  </Container>
</LandingLayout>
