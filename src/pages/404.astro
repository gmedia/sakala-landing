---
import Button from "../components/ui/Button.astro";
import Container from "../components/ui/Container.astro";
import LandingLayout from "../layouts/LandingLayout.astro";
---

<LandingLayout
  title="Halaman tidak ditemukan — Sakala"
  description="Halaman yang kamu cari tidak ditemukan."
  noindex
>
  <Container
    className="flex min-h-[60vh] flex-col items-center justify-center py-20 text-center"
  >
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
      404
    </p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-ink">
      Halaman tidak ditemukan.
    </h1>
    <p class="mt-4 max-w-md leading-7 text-muted">
      Tautan ini mungkin sudah berubah atau belum tersedia selama Sakala terus
      dikembangkan.
    </p>
    <div class="mt-8">
      <Button href="/" prefetch="hover">Kembali ke beranda</Button>
    </div>
  </Container>
</LandingLayout>
